rules_version = '2';

// ===============================================================
//  PROTOTIPO de reglas de seguridad  —  App de vales de gasolina
// ===============================================================
//
//  ⚠️  ADVERTENCIA IMPORTANTE
//  A petición explícita, esta colección permite LECTURA y ESCRITURA
//  SIN AUTENTICACIÓN. El "PIN" de la app es sólo del lado del cliente y
//  NO protege estos datos: cualquiera que conozca el projectId puede leer,
//  crear, modificar o borrar documentos directamente.
//
//  Estas reglas hacen lo ÚNICO posible sin autenticación: validar la FORMA
//  y el TAMAÑO de cada documento para limitar spam, basura y ataques de
//  agotamiento (payloads gigantes). NO controlan QUIÉN accede.
//
//  Si algún día los datos dejan de ser de confianza, la solución real es
//  Firebase Authentication + reglas basadas en el usuario. Con gusto te ayudo.
//
// ===============================================================
//  Modelo de datos asumido
// ===============================================================
//
//  Colección: vales
//  ID de documento: automático (addDoc)
//  Campos:
//    - nombre:         string   (requerido, 1..100)
//    - categoria:      string   (requerido, en ['Empleado','Familia'])
//    - monto:          number   (requerido, en [200, 300, 500, 1000])
//    - fechaVale:      timestamp(requerido; fecha del vale elegida por el usuario)
//    - createdAt:      timestamp(requerido; serverTimestamp() del sistema)
//    - registradoPor:  string   (requerido, 1..100)
//    - notas:          string   (opcional, 0..500)
//    - anulado:        bool      (opcional; borrado suave)
//    - anuladoEn:      timestamp (opcional; cuándo se anuló)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --------- Funciones de ayuda ---------
    function hasOnlyAllowedFields() {
      return request.resource.data.keys().hasOnly(
        ['nombre', 'categoria', 'monto', 'fechaVale', 'createdAt',
         'registradoPor', 'notas', 'anulado', 'anuladoEn']
      );
    }

    function hasRequiredFields() {
      return request.resource.data.keys().hasAll(
        ['nombre', 'categoria', 'monto', 'fechaVale', 'createdAt', 'registradoPor']
      );
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalNotas() {
      return !('notas' in request.resource.data) ||
             (request.resource.data.notas is string &&
              request.resource.data.notas.size() <= 500);
    }

    function isValidOptionalAnulado() {
      return (!('anulado' in request.resource.data) ||
              request.resource.data.anulado is bool) &&
             (!('anuladoEn' in request.resource.data) ||
              request.resource.data.anuladoEn is timestamp);
    }

    // --------- Validador de dominio (usado en create Y update) ---------
    function isValidVale() {
      return hasOnlyAllowedFields() &&
             hasRequiredFields() &&
             isValidString('nombre', 1, 100) &&
             (request.resource.data.categoria in ['Empleado', 'Familia']) &&
             (request.resource.data.monto in [200, 300, 500, 1000]) &&
             request.resource.data.fechaVale is timestamp &&
             request.resource.data.createdAt is timestamp &&
             isValidString('registradoPor', 1, 100) &&
             isValidOptionalNotas() &&
             isValidOptionalAnulado();
    }

    // --------- Colección de vales ---------
    match /vales/{valeId} {
      // Lectura pública (solicitada explícitamente; datos no sensibles).
      allow read: if true;

      // Escritura pública, pero SÓLO si el documento cumple el esquema.
      // El borrado suave (anular) es un 'update' que también pasa por isValidVale().
      allow create: if isValidVale();
      allow update: if isValidVale();

      // Sin borrado físico: se usa borrado suave (anulado = true).
      allow delete: if false;
    }

    // Todo lo demás: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
